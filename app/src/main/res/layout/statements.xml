<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:importantForAccessibility="no"
                android:src="@drawable/backbutton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/btnSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:importantForAccessibility="no" android:src="@drawable/search"
                android:background="@drawable/rounded_search_bg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/statements_123"
                android:textColor="#FFD700"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnBack"/>

            <TextView
                android:id="@+id/tvFormatsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/formats_43"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvTitle"/>

            <TextView
                android:id="@+id/tvPdf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pdf_43"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/rounded_tag_bg"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toEndOf="@+id/tvFormatsLabel"
                app:layout_constraintTop_toTopOf="@+id/tvFormatsLabel"
                app:layout_constraintBottom_toBottomOf="@+id/tvFormatsLabel"/>

            <TextView
                android:id="@+id/tvCsv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/csv_78"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/rounded_tag_bg"
                android:layout_marginStart="6dp"
                app:layout_constraintStart_toEndOf="@+id/tvPdf"
                app:layout_constraintTop_toTopOf="@+id/tvFormatsLabel"
                app:layout_constraintBottom_toBottomOf="@+id/tvFormatsLabel"/>

            <TextView
                android:id="@+id/tvXlsx"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/xlsx_89"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/rounded_tag_bg"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintStart_toEndOf="@+id/tvCsv"
                app:layout_constraintTop_toTopOf="@+id/tvFormatsLabel"
